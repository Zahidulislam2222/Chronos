{
    "name": "zahidulislam/chronos-bridge",
    "description": "Custom WordPress plugin for Chronos luxury watch e-commerce — OOP PHP 8+ with REST API, CPT, caching, cron, and i18n.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Zahidul Islam",
            "homepage": "https://github.com/Zahidulislam2222"
        }
    ],
    "require": {
        "php": ">=8.1",
        "stripe/stripe-php": "^20.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "ChronosBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChronosBridge\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "test": "phpunit"
    }
}
